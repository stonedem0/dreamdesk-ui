{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2019", "DOM"],
    "strict": true,
    "allowJs": true,
    "declaration": true,
    "declarationDir": "js",
    "outDir": "js",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src"]
}
