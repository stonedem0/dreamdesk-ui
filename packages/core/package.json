{
  "name": "@dreamdesk/core",
  "version": "0.1.9",
  "description": "Vanilla JS Web Components for retro-style windows and UI.",
  "type": "module",
  "module": "js/dreamdesk.js",
  "exports": {
    ".": "./js/dreamdesk.js",
    "./css/base.css": "./css/base.css",
    "./css/globals.css": "./css/globals.css",
    "./css/pastelcore.css": "./css/pastelcore.css",
    "./css/dark.css": "./css/dark.css"
  },
  "files": [
    "js/*.js",
    "css/base.css",
    "css/pastelcore.css",
    "css/globals.css",
    "css/dark.css",
    "README.md"
  ],
  "keywords": [
    "web-components",
    "ui",
    "retro",
    "windows",
    "vanilla-js"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "serve": "npx serve . --listen 3001",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "license": "MIT"
}
