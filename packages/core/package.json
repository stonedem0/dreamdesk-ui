{
  "name": "@dreamdesk/core",
  "version": "3.0.1",
  "description": "Vanilla JS Web Components for retro-style windows and UI.",
  "type": "module",
  "module": "js/dreamdesk.js",
  "exports": {
    ".": "./js/dreamdesk.js",
    "./css/base.css": "./css/base.css",
    "./css/globals.css": "./css/globals.css",
    "./css/pastelcore.css": "./css/pastelcore.css",
    "./css/dark.css": "./css/dark.css"
  },
  "files": [
    "js/",
    "css/",
    "README.md"
  ],
  "keywords": [
    "web-components",
    "ui",
    "retro",
    "windows",
    "vanilla-js"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "npx concurrently \"vite build --watch\" \"npx serve . --listen 3001\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
